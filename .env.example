# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────────

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-me-with-a-64-char-random-string

# Get a free key at https://console.groq.com/
GROQ_API_KEY=gsk_...

# ── Optional (defaults shown) ──────────────────────────────────────────────────

# Override the Postgres connection string (already set in docker-compose for Docker)
# DATABASE_URL=postgresql+asyncpg://guitar:guitar@db:5432/guitar_tutor

# Override the Postgres password used by the db service
# POSTGRES_PASSWORD=guitar
